// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EffortLog {
  id         String   @id @default(cuid())
  date       DateTime
  minutes    Int
  category   String
  note       String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  categoryRate Float  @default(25) // Rate at time of logging
  createdAt  DateTime @default(now())
}

model TrafficLog {
  id            String   @id @default(cuid())
  date          DateTime
  campaignName  String?
  organicLeads  Int      @default(0)
  paidLeads     Int      @default(0)
  adSpend       Float    @default(0)
  source        String?  // e.g. "api" | "manual"
  createdAt     DateTime @default(now())
}

model SalesLog {
  id        String   @id @default(cuid())
  date      DateTime
  amount    Float
  source    String?  // "organic" | "paid" | null
  orderId   String?
  createdAt DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(cuid())
  source    String   @unique // "organicLeads" | "paidLeads" | "purchases"
  key       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  email     String   @unique
  password  String   // Hashed with bcrypt
  avatarUrl String?  // Profile picture URL
  role      String   @default("user") // "admin" | "user"
  active    Boolean  @default(true)
  currency  String   @default("EUR") // User's payment currency
  rates     Json     @default("{\"Content Creation\":25,\"Engagement/Community Mgmt\":25,\"Strategy & Planning\":25,\"Analytics & Reporting\":25,\"Ad Management\":25,\"Client Meetings\":25,\"Admin/Misc\":25}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  effortLogs EffortLog[]
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "siteCurrency", "currencyRates"
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}
