# Auto detect text files and perform LF normalization
* text=auto

# TypeScript files
*.ts text eol=lf
*.tsx text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# JSON files
*.json text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.env* text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Prisma schema
*.prisma text eol=lf

# SQL files
*.sql text eol=lf

# Images - binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text

# Fonts - binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary

# Lock files
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf
